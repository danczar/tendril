import { Theme } from "theme.slint";
import { IconClose } from "icons.slint";

export struct QueueItemData {
    job-id: int,
    title: string,
    stage: string,
    progress: float,
    stage-color: color,
    thumbnail: image,
}

export component QueueItem inherits Rectangle {
    in property <QueueItemData> data;
    callback remove();
    callback open-folder();

    // Clickable means: terminal state with an output folder to open.
    property <bool> openable: root.data.stage == "Done";

    // Width of the X-button hit zone on the right edge: 28px button + the
    // HorizontalLayout's padding-right (Theme.space-2 = 8px).
    property <length> x-zone-width: 36px;
    property <bool> over-x: touch.has-hover && touch.mouse-x > root.width - root.x-zone-width;

    height: 72px;
    background: touch.has-hover ? Theme.bg-surface : transparent;
    border-radius: Theme.radius-sm;

    animate background { duration: Theme.duration-normal; easing: ease-out; }

    // Single TouchArea for the whole row. We dispatch click destination by
    // cursor position (right edge = X / remove, elsewhere = open-folder).
    // Using a nested TouchArea for the X caused hover-state thrash at the
    // boundary and a blinking row highlight.
    touch := TouchArea {
        mouse-cursor: (root.over-x || root.openable) ? pointer : default;
        clicked => {
            if root.over-x {
                root.remove();
            } else if root.openable {
                root.open-folder();
            }
        }
    }

    HorizontalLayout {
        padding-left: Theme.space-2;
        padding-right: Theme.space-2;
        spacing: Theme.space-3;

        // Thumbnail
        Rectangle {
            width: 85px;
            height: 48px;
            y: (parent.height - self.height) / 2;
            border-radius: Theme.radius-xs;
            clip: true;
            background: Theme.bg-elevated;

            Image {
                width: 100%;
                height: 100%;
                source: root.data.thumbnail;
                image-fit: cover;
            }

        }

        // Title + stage stacked
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 3px;

            Text {
                text: root.data.title;
                color: Theme.text-primary;
                font-size: Theme.text-base;
                font-weight: 500;
                overflow: elide;
            }

            // Stage label
            Text {
                text: root.data.stage;
                color: root.data.stage-color;
                font-size: Theme.text-sm;
            }

            // Progress bar
            if root.data.progress > 0 && root.data.stage != "Done" && root.data.stage != "Failed" && root.data.stage != "Queued": Rectangle {
                height: 4px;
                background: Theme.bg-base;
                border-radius: 2px;

                Rectangle {
                    width: parent.width * clamp(root.data.progress, 0, 1);
                    height: parent.height;
                    background: root.data.stage-color;
                    border-radius: 2px;

                    animate width { duration: Theme.duration-normal; easing: ease-out; }
                }
            }
        }

        // Remove button (visual only; clicks are dispatched by the outer
        // `touch` TouchArea via `over-x` cursor-position check above).
        Rectangle {
            width: 28px;
            height: 28px;
            y: (parent.height - self.height) / 2;
            border-radius: Theme.radius-xs;
            background: root.over-x ? Theme.bg-surface : transparent;

            animate background { duration: Theme.duration-fast; easing: ease-out; }

            IconClose {
                width: 12px;
                height: 12px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                icon-color: root.over-x ? Theme.text-secondary : Theme.text-tertiary;
                animate icon-color { duration: Theme.duration-fast; easing: ease-out; }
            }
        }
    }
}
