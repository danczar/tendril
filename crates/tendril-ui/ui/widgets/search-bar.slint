import { Theme } from "theme.slint";
import { IconSearch, IconClose } from "icons.slint";

export component SearchBar inherits Rectangle {
    in-out property <string> text;
    in property <bool> searching: false;
    callback submitted(string);
    callback changed(string);
    callback cleared();
    public function focus-input() { input.focus(); }

    height: 44px;
    background: Theme.bg-elevated;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: input.has-focus ? Theme.border-focus : Theme.border-default;

    animate border-color { duration: Theme.duration-normal; easing: ease-out; }

    HorizontalLayout {
        padding-left: Theme.space-4;
        padding-right: Theme.space-3;
        spacing: Theme.space-3;

        Rectangle {
            width: 18px;
            vertical-stretch: 0;

            IconSearch {
                y: (parent.height - self.height) / 2;
                icon-color: input.has-focus ? Theme.text-secondary : Theme.text-tertiary;
                animate icon-color { duration: Theme.duration-normal; easing: ease-out; }
            }
        }

        scope := FocusScope {
            horizontal-stretch: 1;

            key-pressed(event) => {
                if event.text == Key.Escape {
                    root.text = "";
                    root.cleared();
                    accept
                } else {
                    reject
                }
            }

            input := TextInput {
                width: 100%;
                text <=> root.text;
                font-size: Theme.text-md;
                color: Theme.text-primary;
                vertical-alignment: center;

                edited => {
                    root.changed(self.text);
                }
                accepted => {
                    root.submitted(self.text);
                }
            }
        }

        // Clear button — visible only when there's text
        if root.text != "": Rectangle {
            width: 28px;
            height: 28px;
            y: (parent.height - self.height) / 2;
            border-radius: Theme.radius-xs;
            background: clear-touch.has-hover ? Theme.bg-surface : transparent;

            animate background { duration: Theme.duration-fast; easing: ease-out; }

            IconClose {
                width: 14px;
                height: 14px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                icon-color: clear-touch.has-hover ? Theme.text-secondary : Theme.text-tertiary;
                animate icon-color { duration: Theme.duration-fast; easing: ease-out; }
            }

            clear-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.text = "";
                    root.cleared();
                }
            }
        }
    }

    // Loading shimmer — thin bar that slides across the bottom
    if root.searching: Rectangle {
        y: parent.height - 2px;
        height: 2px;
        width: parent.width;
        clip: true;

        Rectangle {
            property <float> phase: Math.mod(animation-tick() / 1ms, 1200) / 1200;

            height: parent.height;
            width: parent.width * 0.3;
            x: phase * (parent.width + self.width) - self.width;
            background: Theme.accent;
            opacity: 0.4 + 0.6 * Math.sin(phase * 180deg);
            border-radius: 1px;
        }
    }
}
