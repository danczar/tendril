        stroke-line-join: round;

        // Arrow down
        MoveTo { x: 12; y: 3; }
        LineTo { x: 12; y: 15; }

        // Arrow head
        MoveTo { x: 7; y: 11; }
        LineTo { x: 12; y: 15; }
        LineTo { x: 17; y: 11; }

        // Tray
        MoveTo { x: 3; y: 17; }
        LineTo { x: 3; y: 20; }
        LineTo { x: 21; y: 20; }
        LineTo { x: 21; y: 17; }
    }
}

export component IconUpdate inherits Rectangle {
    in property <color> icon-color: #5b94d4;
    width: 14px;
