// Outline-style vector icons using stroke rendering.
// Each icon is 18x18 with a configurable color.

export component IconSearch inherits Rectangle {
    in property <color> icon-color: #9c9890;
    width: 18px;
    height: 18px;

    Path {
        width: 100%;
        height: 100%;
        viewbox-width: 24;
        viewbox-height: 24;
        stroke: root.icon-color;
        stroke-width: 2px;
        stroke-line-cap: round;

        // Circle
        MoveTo { x: 11; y: 3; }
        ArcTo { x: 11; y: 19; radius-x: 8; radius-y: 8; }
        ArcTo { x: 11; y: 3; radius-x: 8; radius-y: 8; }
        Close {}

        // Handle
        MoveTo { x: 16.5; y: 16.5; }
        LineTo { x: 21; y: 21; }
    }
}

export component IconGear inherits Rectangle {
    in property <color> icon-color: #9c9890;
    width: 18px;
    height: 18px;

    // Simplified settings icon: three horizontal lines with dots (sliders)
    Path {
        width: 100%;
        height: 100%;
        viewbox-width: 24;
        viewbox-height: 24;
        stroke: root.icon-color;
        stroke-width: 2px;
        stroke-line-cap: round;

        // Top line
        MoveTo { x: 4; y: 6; }
        LineTo { x: 20; y: 6; }

        // Middle line
        MoveTo { x: 4; y: 12; }
        LineTo { x: 20; y: 12; }

        // Bottom line
        MoveTo { x: 4; y: 18; }
        LineTo { x: 20; y: 18; }
    }

    // Slider knobs as small filled circles
    Path {
        width: 100%;
        height: 100%;
        viewbox-width: 24;
        viewbox-height: 24;
        fill: root.icon-color;

        // Top knob at x=15
        MoveTo { x: 15; y: 4; }
        ArcTo { x: 15; y: 8; radius-x: 2; radius-y: 2; }
        ArcTo { x: 15; y: 4; radius-x: 2; radius-y: 2; }
        Close {}

        // Middle knob at x=8
        MoveTo { x: 8; y: 10; }
        ArcTo { x: 8; y: 14; radius-x: 2; radius-y: 2; }
        ArcTo { x: 8; y: 14; radius-x: 2; radius-y: 2; }
        Close {}

        // Bottom knob at x=16
        MoveTo { x: 16; y: 16; }
        ArcTo { x: 16; y: 20; radius-x: 2; radius-y: 2; }
        ArcTo { x: 16; y: 16; radius-x: 2; radius-y: 2; }
        Close {}
    }
}

