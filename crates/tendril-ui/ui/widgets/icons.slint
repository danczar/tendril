export component IconFile inherits Rectangle {
    in property <color> icon-color: #9c9890;
    width: 18px;
    height: 18px;

    Path {
        width: 100%;
        height: 100%;
        viewbox-width: 24;
        viewbox-height: 24;
        stroke: root.icon-color;
        stroke-width: 2px;
        stroke-line-cap: round;
        stroke-line-join: round;

        // Document body
        MoveTo { x: 6; y: 3; }
        LineTo { x: 14; y: 3; }
        LineTo { x: 18; y: 7; }
        LineTo { x: 18; y: 21; }
        LineTo { x: 6; y: 21; }
        Close {}

        // Folded corner
        MoveTo { x: 14; y: 3; }
        LineTo { x: 14; y: 7; }
        LineTo { x: 18; y: 7; }
    }
}

export component IconTendril inherits Rectangle {
    in property <color> icon-color: #5cb896;
    width: 22px;
    height: 22px;

    // Curling vine stem
    Path {
        width: 100%;
        height: 100%;
        viewbox-width: 24;
        viewbox-height: 24;
        stroke: root.icon-color;
        stroke-width: 1.8px;
        stroke-line-cap: round;

        // Main vine — grows up from bottom, curls right
        MoveTo { x: 6; y: 22; }
        CubicTo { x: 6; y: 14; control-1-x: 6; control-1-y: 19; control-2-x: 6; control-2-y: 16; }
        CubicTo { x: 14; y: 6; control-1-x: 6; control-1-y: 10; control-2-x: 9; control-2-y: 7; }

        // Spiral curl at the tip
        CubicTo { x: 19; y: 4; control-1-x: 16; control-1-y: 5; control-2-x: 18; control-2-y: 3.5; }
        CubicTo { x: 17; y: 7; control-1-x: 20; control-1-y: 4.5; control-2-x: 19; control-2-y: 6.5; }
    }

    // Small leaf branching off
    Path {
        width: 100%;
        height: 100%;
        viewbox-width: 24;
        viewbox-height: 24;
        fill: root.icon-color.transparentize(60%);
        stroke: root.icon-color;
        stroke-width: 1.2px;
        stroke-line-cap: round;

        // Leaf shape — branches off to the right from mid-stem
        MoveTo { x: 8; y: 13; }
        CubicTo { x: 14; y: 10; control-1-x: 10; control-1-y: 11; control-2-x: 13; control-2-y: 10; }
        CubicTo { x: 8; y: 13; control-1-x: 13; control-1-y: 12; control-2-x: 10; control-2-y: 13; }
    }
}
