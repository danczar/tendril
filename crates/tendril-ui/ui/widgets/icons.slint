export component IconMusic inherits Rectangle {
    in property <color> icon-color: #615e56;
    width: 18px;
    height: 18px;

    Path {
        width: 100%;
        height: 100%;
        viewbox-width: 24;
        viewbox-height: 24;
        stroke: root.icon-color;
        stroke-width: 2px;
        stroke-line-cap: round;
        stroke-line-join: round;

        // Stem
        MoveTo { x: 9; y: 18; }
        LineTo { x: 9; y: 5; }
        LineTo { x: 21; y: 3; }
        LineTo { x: 21; y: 16; }

        // Left note head
        MoveTo { x: 9; y: 18; }
        ArcTo { x: 3; y: 18; radius-x: 3; radius-y: 2; }
        ArcTo { x: 9; y: 18; radius-x: 3; radius-y: 2; }

        // Right note head
        MoveTo { x: 21; y: 16; }
        ArcTo { x: 15; y: 16; radius-x: 3; radius-y: 2; }
        ArcTo { x: 21; y: 16; radius-x: 3; radius-y: 2; }
    }
}

export component IconDownload inherits Rectangle {
    in property <color> icon-color: #9c9890;
