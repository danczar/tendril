        viewbox-width: 24;
        viewbox-height: 24;
        stroke: root.icon-color;
        stroke-width: 2.5px;
        stroke-line-cap: round;
        stroke-line-join: round;

        // Arrow up
        MoveTo { x: 12; y: 19; }
        LineTo { x: 12; y: 5; }

        // Arrow head
        MoveTo { x: 7; y: 10; }
        LineTo { x: 12; y: 5; }
        LineTo { x: 17; y: 10; }
    }
}

